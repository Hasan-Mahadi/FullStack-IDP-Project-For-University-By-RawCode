# ====================================================================
# IDP ROLE-BASED E-COMMERCE WEB APPLICATION
# ENVIRONMENT VARIABLES TEMPLATE
# ====================================================================
#
# INSTRUCTIONS:
#   1. Copy this file and rename it to: .env
#   2. Fill in your real credentials below.
#   3. NEVER commit the .env file to version control.
#   4. The .env file is already added to .gitignore.
#
# ====================================================================

# ─── EMAIL PROVIDER CONFIGURATION ────────────────────────────────────
#
# Supported providers: gmail | outlook
# Gmail Setup: Use an App Password (NOT your regular Google password).
#   Guide: https://support.google.com/accounts/answer/185833
#
# Outlook Setup: Use your regular Outlook/Hotmail password.
#   SMTP Host: smtp.office365.com | Port: 587
#
EMAIL_PROVIDER=gmail

# Your full email address (sender)
EMAIL_USER=your_email@gmail.com

# Gmail: App Password (16 chars, no spaces)
# Outlook: Your account password
EMAIL_PASSWORD=your_app_password_here

# Display name shown in the "From" field of emails
EMAIL_FROM_NAME=EduShop Support

# ─── APPLICATION ENVIRONMENT ─────────────────────────────────────────
# Values: development | production
NODE_ENV=development

# ─── SERVER CONFIGURATION ────────────────────────────────────────────
PORT=3001
